<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/calculator_card_background"
    app:cardCornerRadius="@dimen/calculator_button_corner"
    app:cardElevation="0dp"
    app:strokeColor="@color/calculator_input_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/CalculatorTextInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="@dimen/calculator_button_margin"
            android:layout_weight="1"
            android:hint="@string/gpa_subject_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSubjectName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <Spinner
            android:id="@+id/spinnerCredit"
            android:layout_width="0dp"
            android:layout_height="@dimen/gpa_row_control_height"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="@dimen/calculator_button_margin"
            android:layout_weight="0.8"
            android:background="@drawable/bg_calculator_button_number"
            android:padding="4dp" />

        <Spinner
            android:id="@+id/spinnerGrade"
            android:layout_width="0dp"
            android:layout_height="@dimen/gpa_row_control_height"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="@dimen/calculator_button_margin"
            android:layout_weight="0.75"
            android:background="@drawable/bg_calculator_button_number"
            android:padding="4dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDeleteCourse"
            style="@style/CalculatorButton.RowAction"
            android:layout_gravity="center_vertical"
            android:contentDescription="@string/gpa_delete_course"
            android:text="×"
            android:textSize="22sp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
