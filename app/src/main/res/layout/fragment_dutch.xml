<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/calculator_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/calculator_screen_padding">

        <TextView
            style="@style/CalculatorScreenTitle"
            android:layout_marginBottom="16dp"
            android:text="@string/nav_dutch" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilTotalAmount"
            style="@style/CalculatorTextInput"
            android:layout_marginBottom="12dp"
            android:hint="@string/dutch_total_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTotalAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/dutch_people_hint"
            android:textColor="@color/calculator_result_text"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnDecreasePeople"
                style="@style/CalculatorButton.Secondary"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@string/dutch_decrease"
                android:text="-" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPeopleCount"
                style="@style/CalculatorTextInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPeopleCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:inputType="number"
                    android:text="2" />

            </com.google.android.material.textfield.TextInputLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnIncreasePeople"
                style="@style/CalculatorButton.Secondary"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="8dp"
                android:contentDescription="@string/dutch_increase"
                android:text="+" />

        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCalculateDutch"
            style="@style/CalculatorButton.Primary"
            android:layout_marginBottom="24dp"
            android:text="@string/dutch_calculate" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDutchResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardBackgroundColor="@color/calculator_card_background"
            app:cardCornerRadius="@dimen/calculator_button_corner"
            app:cardElevation="2dp"
            app:strokeColor="@color/calculator_button_operator"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dutch_per_person_label"
                    android:textColor="@color/calculator_result_text"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPerPersonAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/calculator_button_operator"
                    android:textSize="32sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvDutchError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/error_text"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
